    <!-- SCRIPT DU GRAPHIQUE -->
    <script>
        document.addEventListener('livewire:navigated', () => {
            const ctx = document.getElementById('sensorDoubleChart');
            if (!ctx) return;

            const chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: Array(20).fill(''), 
                    datasets: [
                        {
                            label: 'Temp',
                            data: Array(20).fill({{ $temperature }}),
                            borderColor: '#22d3ee',
                            borderWidth: 3,
                            tension: 0.4,
                            pointRadius: 0,
                            fill: true,
                            backgroundColor: 'rgba(34, 211, 238, 0.05)'
                        },
                        {
                            label: 'Hum',
                            data: Array(20).fill({{ $humidity }}),
                            borderColor: '#3b82f6',
                            borderWidth: 3,
                            tension: 0.4,
                            pointRadius: 0,
                            fill: true,
                            backgroundColor: 'rgba(59, 130, 246, 0.05)'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { display: false },
                        y: { display: false, beginAtZero: false }
                    }
                }
            });

            // Écoute l'événement dispatché par PHP
            window.addEventListener('update-sensor-chart', (event) => {
                const { temp, hum } = event.detail[0];

                chart.data.datasets[0].data.push(temp);
                chart.data.datasets[0].data.shift();
                
                chart.data.datasets[1].data.push(hum);
                chart.data.datasets[1].data.shift();
                
                chart.update('none');
            });
        });
    </script>
